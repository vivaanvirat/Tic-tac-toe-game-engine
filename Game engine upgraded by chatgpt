import pygame

pygame.init()


class TicTacToe:
    """Simple Tic-Tac-Toe game."""

    EMPTY = 0
    X = 1
    O = 2

    def __init__(self):
        # Window settings
        self.width = 800
        self.height = 600

        self.screen = pygame.display.set_mode((self.width, self.height))
        pygame.display.set_caption("Tic-Tac-Toe")

        self.clock = pygame.time.Clock()

        # Board settings
        self.rows = 3
        self.cols = 3

        self.cell_width = self.width // self.cols
        self.cell_height = self.height // self.rows

        # Game state
        self.board = [
            [self.EMPTY, self.EMPTY, self.EMPTY],
            [self.EMPTY, self.EMPTY, self.EMPTY],
            [self.EMPTY, self.EMPTY, self.EMPTY]
        ]

        self.current_player = self.O
        self.running = True

    # ==========================================================
    # Drawing
    # ==========================================================

    def draw_board(self):
        """Draw grid lines."""

        self.screen.fill((255, 255, 255))

        for col in range(1, self.cols):
            x = col * self.cell_width
            pygame.draw.line(
                self.screen,
                (0, 0, 0),
                (x, 0),
                (x, self.height),
                3
            )

        for row in range(1, self.rows):
            y = row * self.cell_height
            pygame.draw.line(
                self.screen,
                (0, 0, 0),
                (0, y),
                (self.width, y),
                3
            )

    def draw_pieces(self):
        """Draw X and O pieces."""

        for row in range(self.rows):
            for col in range(self.cols):

                center_x = col * self.cell_width + self.cell_width // 2
                center_y = row * self.cell_height + self.cell_height // 2

                value = self.board[row][col]

                if value == self.O:
                    pygame.draw.circle(
                        self.screen,
                        (0, 0, 0),
                        (center_x, center_y),
                        80,
                        5
                    )

                elif value == self.X:
                    offset = 50

                    pygame.draw.line(
                        self.screen,
                        (0, 0, 0),
                        (center_x - offset, center_y - offset),
                        (center_x + offset, center_y + offset),
                        5
                    )

                    pygame.draw.line(
                        self.screen,
                        (0, 0, 0),
                        (center_x + offset, center_y - offset),
                        (center_x - offset, center_y + offset),
                        5
                    )

    # ==========================================================
    # Board Helpers
    # ==========================================================

    def mouse_to_cell(self, x, y):
        """
        Convert mouse coordinates into board coordinates.

        Returns:
            (row, col)
        """

        col = x // self.cell_width
        row = y // self.cell_height

        return row, col

    def is_valid_move(self, row, col):
        """Check whether a move is legal."""

        return self.board[row][col] == self.EMPTY

    def make_move(self, row, col):
        """Place current player's piece."""

        self.board[row][col] = self.current_player

        # Switch turns
        self.current_player = (
            self.X if self.current_player == self.O else self.O
        )

    # ==========================================================
    # Win Detection
    # ==========================================================

    def check_winner(self):
        """
        Returns:
            0 -> no winner
            1 -> X wins
            2 -> O wins
        """

        # Rows
        for row in self.board:
            if row[0] != self.EMPTY and row[0] == row[1] == row[2]:
                return row[0]

        # Columns
        for col in range(3):
            if (
                self.board[0][col] != self.EMPTY
                and self.board[0][col]
                == self.board[1][col]
                == self.board[2][col]
            ):
                return self.board[0][col]

        # Main diagonal
        if (
            self.board[0][0] != self.EMPTY
            and self.board[0][0]
            == self.board[1][1]
            == self.board[2][2]
        ):
            return self.board[0][0]

        # Anti-diagonal
        if (
            self.board[0][2] != self.EMPTY
            and self.board[0][2]
            == self.board[1][1]
            == self.board[2][0]
        ):
            return self.board[0][2]

        return self.EMPTY

    def is_draw(self):
        """Check for tie game."""

        if self.check_winner():
            return False

        for row in self.board:
            if self.EMPTY in row:
                return False

        return True

    # ==========================================================
    # Event Handling
    # ==========================================================

    def handle_click(self, x, y):

        row, col = self.mouse_to_cell(x, y)

        if not self.is_valid_move(row, col):
            return

        self.make_move(row, col)

        winner = self.check_winner()

        if winner == self.X:
            print("X wins!")
            self.running = False

        elif winner == self.O:
            print("O wins!")
            self.running = False

        elif self.is_draw():
            print("Draw!")
            self.running = False

    # ==========================================================
    # Main Loop
    # ==========================================================

    def run(self):

        while self.running:

            for event in pygame.event.get():

                if event.type == pygame.QUIT:
                    self.running = False

                elif event.type == pygame.MOUSEBUTTONDOWN:

                    if event.button == 1:
                        self.handle_click(*event.pos)

            self.draw_board()
            self.draw_pieces()

            pygame.display.flip()
            self.clock.tick(60)

        pygame.quit()


if __name__ == "__main__":
    game = TicTacToe()
    game.run()
